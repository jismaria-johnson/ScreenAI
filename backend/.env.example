# PostgreSQL connection URL. Leave empty to keep using local SQLite.
# Example: postgresql://screenai:strong-password@127.0.0.1:5432/screenai
DATABASE_URL=
DATABASE_CONN_MAX_AGE=60

# --- Django settings ---
DJANGO_SECRET_KEY=development-only-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
TRUST_PROXY_HEADERS=False

# --- Supabase Storage Configuration ---
SUPABASE_STORAGE_ENABLED=False
SUPABASE_STORAGE_BUCKET=screenai-files
SUPABASE_S3_ENDPOINT_URL=
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
SUPABASE_S3_REGION=
SUPABASE_STORAGE_URL_EXPIRY_SECONDS=3600

# --- Feature Flags ---
EVALUATION_ENABLED=True

# --- Gemini Settings ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# --- Stage 3: Brevo Assessment Invitation Settings ---
# Get your API key from the Brevo Dashboard -> SMTP & API -> API Keys
BREVO_API_KEY=your-brevo-api-key-here
BREVO_API_BASE_URL=https://api.brevo.com/v3
# Must be a verified sender domain or email in Brevo -> Senders & Domains -> Senders
BREVO_SENDER_EMAIL=no-reply@screenai.com
BREVO_SENDER_NAME=ScreenAI
# Generate a secure string (e.g. openssl rand -hex 24) to authenticate webhook requests.
BREVO_WEBHOOK_SECRET=your-webhook-secret-here
BREVO_REQUEST_TIMEOUT_SECONDS=10
# Base URL for candidate assessment landing page (e.g. http://localhost:5173/assessments in development)
ASSESSMENT_FRONTEND_URL=http://localhost:5173/assessments
MAX_INVITATION_LIFETIME_DAYS=30
# Set to True to enable live Brevo email delivery. If False, email delivery is deactivated on the server.
ASSESSMENT_INVITATIONS_ENABLED=False
MAX_NOTEBOOK_UPLOAD_SIZE=2097152

# --- Stage 5: Secure Notebook Evaluation Settings ---
EVALUATOR_DOCKER_IMAGE=python:3.11-slim
EVALUATOR_TIMEOUT_SECONDS=30
EVALUATOR_MEMORY_MB=256
EVALUATOR_CPU_LIMIT=1.0
EVALUATOR_MAX_OUTPUT_BYTES=51200
EVALUATOR_STALE_TIMEOUT_SECONDS=300
EVALUATOR_MAX_RETRIES=3
EVALUATOR_POLL_INTERVAL_SECONDS=10
